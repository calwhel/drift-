# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/drift?sslmode=require

# Wallet encryption for custodial generated wallets (32+ char random; falls back to NEXTAUTH_SECRET)
WALLET_ENCRYPTION_KEY=generate-a-random-encryption-key-at-least-32-chars

# NextAuth — on Railway leave blank; scripts/start.cjs auto-sets from RAILWAY_PUBLIC_DOMAIN.
# If you set this manually it MUST match your live Railway URL exactly (no stale domains).
NEXTAUTH_URL=
NEXTAUTH_SECRET=generate-a-random-secret-at-least-32-chars

# HD wallet mnemonic for unique per-link deposit addresses (BIP39, 12 or 24 words)
# NEVER commit the real mnemonic. Generate a new one for production.
MASTER_WALLET_MNEMONIC=abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about

# Platform fee collection wallet
PLATFORM_FEE_WALLET=TPa7x6h9Q8mR2ygJ6K1b8v5d3f9a2e1c7

# Fallback holding wallets (used when mnemonic unavailable)
DEFAULT_HOLDING_WALLET=TPa7x6h9Q8mR2ygJ6K1b8v5d3f9a2e1c7
HOLDING_WALLET_USDT_TRC20=TPa7x6h9Q8mR2ygJ6K1b8v5d3f9a2e1c7
HOLDING_WALLET_USDC_ERC20=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
HOLDING_WALLET_BTC_Bitcoin=bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh
HOLDING_WALLET_ETH_ERC20=0x8f3Cf7ad23Cd3CaDbD9735AFf958023239c6A063
HOLDING_WALLET_BNB_BEP20=0x8894E0a0c962CB723c1976a4421c95949bE2D4E3
HOLDING_WALLET_SOL_Solana=YourSolanaHoldingWalletAddress

# Blockchain API keys (for transaction polling every 30s)
TRONGRID_API_KEY=
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ETH_RPC_URL=https://eth.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Cron job authentication (call GET /api/cron/poll-payments every 30s)
CRON_SECRET=generate-another-random-secret
